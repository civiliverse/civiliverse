{
  "name": "@civiliverse/data-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Civiliverse schemas, data validation, icon indexing, and image ingestion tools.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "civiliverse-data": "dist/tools/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm run typecheck && pnpm run test && pnpm run schema:export && pnpm run validate",
    "schema:export": "tsx schema/export-json-schema.ts",
    "start": "tsx tools/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "tsx tools/cli.ts validate"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "fast-glob": "^3.3.3",
    "sharp": "^0.34.3",
    "yaml": "^2.8.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.9.0"
}
